dataset_path: cambridgeltl/vsr_random
dataset_name: default
output_type: generate_until
doc_to_visual: !function utils.vsr_doc_to_visual
doc_to_text: !function utils.vsr_doc_to_text
doc_to_target: !function utils.vsr_doc_to_target
process_results: !function utils.vsr_process_results

metric_list:
  - metric: vsr_accuracy
    aggregation: mean
    higher_is_better: true

lmms_eval_specific_kwargs:
  default:
    pre_prompt: ""
    post_prompt: "\nFor this binary relation check, output 1 only when the relation is clearly supported by visual evidence and no strong contradictory cue exists; otherwise output 0. Use image semantics (occlusion, relative depth, object orientation/axis, boundary contact) and do not rely on rough box overlap or x/y ordering alone.\nanswer 0 if the statement is False and 1 if the statement is True.\nOutput exactly one <reason>...</reason> and one <answer>...</answer>. Put only 0 or 1 inside <answer>, and close both tags."

generation_kwargs:
  max_new_tokens: 128
  temperature: 0
  top_p: 1.0
  num_beams: 1
  do_sample: false

metadata:
  version: "0.0"
